# MySQL Database (provided by Railway MySQL service)
WORDPRESS_DB_HOST=mysql.railway.internal:3306
WORDPRESS_DB_NAME=railway
WORDPRESS_DB_USER=root
WORDPRESS_DB_PASSWORD=your_password_here

# WordPress table prefix (must match your OVH backup)
WORDPRESS_TABLE_PREFIX=wor9551_

# Site URLs
WORDPRESS_CONFIG_EXTRA=define('WP_HOME','https://www.optinoc.com'); define('WP_SITEURL','https://www.optinoc.com'); define('FORCE_SSL_ADMIN', true); if (isset($$_SERVER['HTTP_X_FORWARDED_PROTO']) && $$_SERVER['HTTP_X_FORWARDED_PROTO'] === 'https') { $$_SERVER['HTTPS'] = 'on'; }

# Railway provides this automatically
PORT=8080
